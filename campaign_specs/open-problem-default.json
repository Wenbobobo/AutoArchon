{
  "campaignMode": "open_problem",
  "campaignRoot": "${CAMPAIGNS_ROOT}/${RUN_TAG}-open-problem-default",
  "sourceRoot": "${SOURCE_ROOTS_ROOT}/open-problem-upstream",
  "reuseLakeFrom": "${SOURCE_ROOTS_ROOT}/open-problem-upstream",
  "runSpecOutput": "${RUN_SPECS_ROOT}/${RUN_TAG}-open-problem-default.json",
  "teacherModel": "${MODEL}",
  "teacherReasoningEffort": "${REASONING_EFFORT}",
  "preloadHistoricalRoutes": true,
  "planShards": {
    "matchRegex": "^.*\\.lean$",
    "shardSize": 2,
    "runIdPrefix": "teacher-o",
    "runIdMode": "index"
  },
  "watchdog": {
    "model": "${MODEL}",
    "reasoningEffort": "${REASONING_EFFORT}",
    "pollSeconds": 30,
    "stallSeconds": 300,
    "bootstrapLaunchAfterSeconds": 45,
    "maxRestarts": 3,
    "ownerSilenceSeconds": 1200,
    "maxActiveLaunches": 2,
    "launchBatchSize": 1,
    "launchCooldownSeconds": 90,
    "finalizeOnTerminal": true,
    "pruneWorkspaceLake": true,
    "pruneBrokenPrewarm": true
  },
  "environment": {
    "ARCHON_CODEX_READY_RETRIES": "${ARCHON_CODEX_READY_RETRIES}",
    "ARCHON_CODEX_READY_RETRY_DELAY_SECONDS": "${ARCHON_CODEX_READY_RETRY_DELAY_SECONDS}"
  }
}
